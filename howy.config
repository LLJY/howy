# Known-good local machine deployment config for current testing.
# This file is intentionally tuned for the local host, including CPU inference
# and /dev/video2. Do not assume these values are portable to other machines.

[core]
detection_notice = false
timeout_notice = true
no_confirmation = false
suppress_unknown = false
# Current pam_howy does not yet honor this config knob directly; it still uses
# built-in SSH-session heuristics.
abort_if_ssh = false
# Current pam_howy does not yet honor this config knob directly; it still uses
# built-in lid-state heuristics.
abort_if_lid_closed = false
disabled = false

[ml]
# Use the provider priority chain for this machine. On first successful startup,
# howyd will persist the resolved provider to /var/cache/howy/provider-selection.txt
# and reuse it on later boots unless you override the config or clear that cache.
# scripts/install-local.sh also runs a one-shot prewarm for "migraphx"/"auto"
# and keeps compiled .mxr cache under /var/cache/howy; clear those files (and the
# provider-selection.txt cache) if the model, ONNX Runtime, ROCm/MIGraphX stack,
# or GPU arch changes.
provider = "auto"
prefer_npu = false
det_threshold = 0.3
recognition_threshold = 0.5
detector_model = "/home/lucas/Projects/howy/dist/howdy_onnx/_internal/onnx-data/det_10g.onnx"
recognizer_model = "/home/lucas/Projects/howy/dist/howdy_onnx/_internal/onnx-data/w600k_r50.onnx"
det_width = 640
det_height = 640
threads = 0

[video]
timeout = 8
# Known-good local camera path for this machine.
device_path = "/dev/video2"
max_height = 360
dark_threshold = 95.0
frame_width = 640
frame_height = 360
rotate = 0

[snapshots]
save_failed = false
save_successful = false

[credentials]
# Experimental and intentionally disabled for the current PAM deployment until
# session-scoped caching is implemented end-to-end.
enable_cache = false
cache_ttl_secs = 300
keyring_prefix = "howy:auth"
use_systemd_creds = false

[debug]
end_report = false
log_level = "info"
